# RAGSPRO / PUPPYCHEF WhatsApp AI Agent Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# BOT MODE (CRITICAL)
# ============================================
# Options: 'ragspro' | 'ai' | 'state'
# ragspro = RAGSPRO Founder AI Agent
# ai = Legacy PUPPYCHEF AI Agent
# state = Legacy PUPPYCHEF rule-based
BOT_MODE=ragspro

# ============================================
# WHATSAPP BUSINESS API (Meta)
# ============================================
# Get from: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WHATSAPP_TOKEN=your_whatsapp_business_api_token_here
PHONE_NUMBER_ID=your_phone_number_id_here
VERIFY_TOKEN=ragspro_verify_token_123

# ============================================
# NVIDIA NIM AI (for RAGSPRO Agent)
# ============================================
# Get from: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# ============================================
# N8N INTEGRATION (for Agency Lead Management)
# ============================================
# Your n8n webhook URL for receiving leads
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/ragspro-leads
# Optional: Webhook key for authentication
N8N_WEBHOOK_KEY=your_webhook_key_here

# ============================================
# SERVER CONFIG
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# OPTIONAL: GOOGLE SHEETS (for production)
# ============================================
# GOOGLE_SHEETS_ID=your_google_sheets_id
# GOOGLE_SERVICE_ACCOUNT_KEY=path/to/service-account.json

# ============================================
# OPTIONAL: PAYMENT INTEGRATION (for production)
# ============================================
# RAZORPAY_KEY_ID=your_razorpay_key
# RAZORPAY_KEY_SECRET=your_razorpay_secret

# ============================================
# OPTIONAL: NOTIFICATIONS
# ============================================
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# ADMIN_PHONE=your_admin_phone_number
